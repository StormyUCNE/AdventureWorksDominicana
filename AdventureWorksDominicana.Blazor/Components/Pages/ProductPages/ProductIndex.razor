@page "/Product/Index"

@inject ProductService productService;
@rendermode InteractiveServer

<div class="container">
    <div class="card shadow-lg">
        <div class="card-header d-flex justify-content-between">
            <h4>Products</h4>
            <a class="btn btn-primary bi bi-plus-square" href="/Product/Create"> Crear</a>
        </div>
        <div class="card-body">
            @* Encabezados *@
            <div class="row">
                <div class="col-3">
                    <label>Desde (Modificación):</label>
                </div>
                <div class="col-3">
                    <label>Hasta (Modificación):</label>
                </div>
                <div class="col-3">
                    <label>Filtro:</label>
                </div>
                <div class="col-3">
                    <label>Buscar:</label>
                </div>
            </div>

            @* Inputs *@
            <div class="row pb-3">
                <div class="col-3">
                    <input class="form-control" type="datetime-local" @bind-value="FechaDesde" />
                </div>
                <div class="col-3">
                    <input class="form-control" type="datetime-local" @bind-value="FechaHasta" />
                </div>
                <div class="col-3">
                    <select class="form-select" @bind="Filtro">
                        <option value="" disabled selected hidden>Seleccione un filtro...</option>
                        <option value="Nombre">Nombre del Producto</option>
                        <option value="Numero">Número/SKU</option>
                        <option value="Subcategoria">Subcategoría</option>
                    </select>
                </div>
                <div class="col-3">
                    <div class="input-group">
                        <input class="form-control" type="text" @bind-value="ValorFiltro" placeholder="Buscar..." />
                        <button class="btn btn-primary bi bi-search" type="button" @onclick="Filtrar"></button>
                        <button class="btn btn-outline-primary bi bi-arrow-clockwise" type="button" @onclick="Restablecer"></button>
                    </div>
                </div>
            </div>

            <div class="table-responsive">
                <QuickGrid Class="table table-striped table-bordered table-hover" Pagination="@pages" Items="ListaProducts.AsQueryable()" ItemKey="@(p => p.ProductId)">
                    <PropertyColumn Property="@(p => p.ProductId)" Sortable="true" Title="Id"></PropertyColumn>
                    <PropertyColumn Property="@(p => p.ProductNumber)" Sortable="true" Title="SKU"></PropertyColumn>
                    <PropertyColumn Property="@(p => p.Name)" Sortable="true" Title="Nombre"></PropertyColumn>
                    
                    <TemplateColumn Class="text-left" Context="product" Title="Subcategoría">
                        @if (product.ProductSubcategory != null)
                        {
                            <span>@product.ProductSubcategory.Name</span>
                        }
                        else
                        {
                            <span class="text-muted">N/A</span>
                        }
                    </TemplateColumn>

                    <PropertyColumn Property="@(p => p.StandardCost)" Sortable="true" Format="C2" Title="Costo"></PropertyColumn>
                    <PropertyColumn Property="@(p => p.ListPrice)" Sortable="true" Format="C2" Title="Precio"></PropertyColumn>
                    
                    <TemplateColumn Class="text-center" Context="product" Title="Estado">
                        @if (product.SellEndDate == null)
                        {
                            <span class="badge bg-success">Activo</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Inactivo</span>
                        }
                    </TemplateColumn>
                    
                    <TemplateColumn Class="text-center" Context="options" Title="Acci&oacute;n">
                        <a href="/Product/Edit/@options.ProductId" class="btn btn-outline-primary bi bi-pencil-square"> Modificar</a>
                    </TemplateColumn>
                </QuickGrid>
            </div>
            @*Pagination*@
            <Paginator State="@pages" />
        </div>
    </div>
</div>

@code {
    public List<Product> ListaProducts { get; set; } = new List<Product>();
    public DateTime? FechaDesde { get; set; }
    public DateTime? FechaHasta { get; set; }
    public string Filtro { get; set; } = "";
    public string ValorFiltro { get; set; } = "";
    private PaginationState pages = new PaginationState { ItemsPerPage = 10 }; // Cambiado a 10 porque el catálogo suele ser amplio

    protected override async Task OnInitializedAsync()
    {
        ListaProducts = await productService.GetList(p => p.ProductId > 0);
        ListaProducts = ListaProducts.OrderByDescending(p => p.ModifiedDate).ToList();
    }

    public async Task Filtrar()
    {
        Expression<Func<Product, bool>> criterio = p => p.ProductId > 0;

        // FILTROS DE FECHA (Usando ModifiedDate, vital para auditoría de productos)
        if (FechaDesde.HasValue && FechaHasta.HasValue)
        {
            DateTime fechaHastaStr = FechaHasta.Value.Date.AddDays(1).AddTicks(-1);
            criterio = criterio.And(p => p.ModifiedDate >= FechaDesde.Value && p.ModifiedDate <= fechaHastaStr);
        }
        else if (FechaDesde.HasValue)
        {
            criterio = criterio.And(p => p.ModifiedDate >= FechaDesde.Value);
        }
        else if (FechaHasta.HasValue)
        {
            var fechaHastaStr = FechaHasta.Value.Date.AddDays(1).AddTicks(-1);
            criterio = criterio.And(p => p.ModifiedDate <= fechaHastaStr);
        }

        // FILTROS DE TEXTO
        if (!string.IsNullOrEmpty(Filtro) && !string.IsNullOrEmpty(ValorFiltro))
        {
            if (Filtro == "Nombre")
            {
                criterio = criterio.And(p => p.Name.Trim().ToLower().Contains(ValorFiltro.ToLower()));
            }
            else if (Filtro == "Numero")
            {
                criterio = criterio.And(p => p.ProductNumber.Trim().ToLower().Contains(ValorFiltro.ToLower()));
            }
            else if (Filtro == "Subcategoria")
            {
                // Validación de null conditional en expresiones requiere cuidado, pero como ya incluimos Subcategory en GetList:
                criterio = criterio.And(p => p.ProductSubcategory != null && p.ProductSubcategory.Name.Trim().ToLower().Contains(ValorFiltro.ToLower()));
            }
        }

        ListaProducts = await productService.GetList(criterio);
        ListaProducts = ListaProducts.OrderByDescending(s => s.ModifiedDate).ToList();
    }

    public async Task Restablecer()
    {
        FechaDesde = null;
        FechaHasta = null;
        Filtro = "";
        ValorFiltro = "";
        await Filtrar();
    }
}
